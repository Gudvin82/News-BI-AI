# Which bot profile from config/bots.json to run
BOT_SLUG=youpiter_quiz_bot
TELEGRAM_BOT_TOKEN=

# Debug logs
DEBUG=false

# Bitrix integration mode: webhook | api | disabled
BITRIX_MODE=disabled

# For webhook mode
BITRIX_WEBHOOK_URL=https://your-domain.bitrix24.ru/rest/1/your_webhook_key/crm.lead.add.json

# For API mode
BITRIX_API_URL=https://your-domain.bitrix24.ru/rest/crm.lead.add.json
BITRIX_ACCESS_TOKEN=
BITRIX_ASSIGNED_BY_ID=1
