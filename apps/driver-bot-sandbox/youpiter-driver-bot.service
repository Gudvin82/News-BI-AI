[Unit]
Description=Youpiter Driver Hiring Telegram Bot
After=network.target

[Service]
Type=simple
WorkingDirectory=/opt/youpiter-driver-bot
EnvironmentFile=/opt/youpiter-driver-bot/config/.env
ExecStart=/opt/youpiter-driver-bot/.venv/bin/python main.py
Restart=always
RestartSec=5
User=root

[Install]
WantedBy=multi-user.target
